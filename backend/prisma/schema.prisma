generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  account_id Int      @id @default(autoincrement())
  status     String   @default("active")
  type       String
  username   String   @unique
  password   String
  email      String   @unique
  created_at DateTime @default(now())

  manager  Manager?
  customer Customer?
  staff    Staff?

  @@map("Account")
}

model Manager {
  manager_id        Int     @id @default(autoincrement())
  account_id        Int     @unique
  full_name         String
  managed_id        String? @unique
  phone_number      String?
  organization_name String?

  account             Account             @relation(fields: [account_id], references: [account_id], onDelete: Cascade)
  gardens             Garden[]
  counterfeit_reports CounterfeitReport[] @relation("ResolvedByManager")

  @@map("Manager")
}

model Customer {
  customer_id  Int     @id @default(autoincrement())
  account_id   Int     @unique
  full_name    String
  phone_number String?
  update_log   String?

  account             Account             @relation(fields: [account_id], references: [account_id], onDelete: Cascade)
  transactions        Transaction[]
  counterfeit_reports CounterfeitReport[]

  @@map("Customer")
}

model Garden {
  garden_id       Int       @id @default(autoincrement())
  manager_id      Int
  name            String
  area            Decimal?
  street          String?
  city            String?
  soil_type       String?
  registered_date DateTime? @default(now())

  manager        Manager         @relation(fields: [manager_id], references: [manager_id])
  staff          Staff[]
  certifications Certification[]
  products       Product[]

  @@map("Garden")
}

model Staff {
  staff_id   Int     @id @default(autoincrement())
  garden_id  Int
  account_id Int?    @unique
  full_name  String
  phone      String?
  position   String?

  garden  Garden   @relation(fields: [garden_id], references: [garden_id])
  account Account? @relation(fields: [account_id], references: [account_id])

  @@map("Staff")
}

model Certification {
  certification_id  Int       @id @default(autoincrement())
  garden_id         Int
  name              String
  issue_date        DateTime?
  expiry_date       DateTime?
  issuing_authority String?

  garden Garden @relation(fields: [garden_id], references: [garden_id])

  @@map("Certification")
}

model Product {
  product_id   Int       @id @default(autoincrement())
  garden_id    Int
  product_name String
  type         String?
  description  String?
  quality      String?
  area         Decimal?
  species      String?
  unit_price   Decimal?
  created_at   DateTime  @default(now())

  garden              Garden              @relation(fields: [garden_id], references: [garden_id])
  batches             Batch[]
  counterfeit_reports CounterfeitReport[]

  @@map("Product")
}

model Batch {
  batch_id         Int       @id @default(autoincrement())
  product_id       Int
  batch_no         String    @unique
  harvest_date     DateTime?
  expiry_date      DateTime?
  initial_quantity Decimal?
  current_quantity Decimal?
  status           String    @default("available")
  created_at       DateTime  @default(now())

  product             Product             @relation(fields: [product_id], references: [product_id])
  transaction_details TransactionDetail[]

  @@map("Batch")
}

model Transaction {
  transaction_id   Int       @id @default(autoincrement())
  customer_id      Int
  transaction_date DateTime  @default(now())
  street           String?
  city             String?
  status           String    @default("pending")
  total_amount     Decimal?
  notes            String?

  customer            Customer            @relation(fields: [customer_id], references: [customer_id])
  transaction_details TransactionDetail[]

  @@map("Transaction")
}

model TransactionDetail {
  detail_id      Int     @id @default(autoincrement())
  transaction_id Int
  batch_id       Int
  unit_price     Decimal
  quantity       Decimal

  transaction Transaction @relation(fields: [transaction_id], references: [transaction_id])
  batch       Batch       @relation(fields: [batch_id], references: [batch_id])

  @@map("Transaction_Detail")
}

model CounterfeitReport {
  report_id     Int       @id @default(autoincrement())
  customer_id   Int
  product_id    Int
  report_date   DateTime  @default(now())
  location      String?
  detected_date DateTime?
  fake_method   String?
  evidence_url  String?
  status        String    @default("pending")
  conclusion    String?
  resolved_by   Int?
  resolved_at   DateTime?

  customer Customer  @relation(fields: [customer_id], references: [customer_id])
  product  Product   @relation(fields: [product_id], references: [product_id])
  manager  Manager?  @relation("ResolvedByManager", fields: [resolved_by], references: [manager_id])

  @@map("Counterfeit_Report")
}
